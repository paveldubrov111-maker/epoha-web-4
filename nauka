// ─────────────────────────────────────────
// CALCULATORS
// ─────────────────────────────────────────
function cBudget(v) {
  const n = parseInt(v)||50000;
  document.getElementById('cb-v').textContent = fmt(n);
  document.getElementById('cb-n').textContent = fmt(n*.5)+' грн';
  document.getElementById('cb-w').textContent = fmt(n*.3)+' грн';
  document.getElementById('cb-s').textContent = fmt(n*.2)+' грн';
}
function cCush(v) {
  const n = parseInt(v)||25000;
  document.getElementById('cc-v').textContent = fmt(n);
  document.getElementById('cc-3').textContent = fmt(n*3)+' грн';
  document.getElementById('cc-6').textContent = fmt(n*6)+' грн';
  document.getElementById('cc-9').textContent = fmt(n*9)+' грн';
}
function cComp() {
  const pv=parseInt(document.getElementById('cp-pv')?.value)||20000;
  const pm=parseInt(document.getElementById('cp-pm')?.value)||5000;
  const r=parseFloat(document.getElementById('cp-r')?.value)/100||.15;
  const n=parseInt(document.getElementById('cp-n')?.value)||15;
  ['cp-pv','cp-pm','cp-r','cp-n'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el)return;
    const v=parseFloat(el.value);
    const s=id==='cp-r'?Math.round(v)+'%':fmt(v);
    el.nextElementSibling.textContent=s;
  });
  const mr=r/12,nm=n*12;
  const fv=pv*Math.pow(1+mr,nm)+pm*(Math.pow(1+mr,nm)-1)/mr;
  const inv=pv+pm*nm;
  if(document.getElementById('cp-inv'))document.getElementById('cp-inv').textContent=fmt(inv)+' грн';
  if(document.getElementById('cp-tot'))document.getElementById('cp-tot').textContent=fmt(fv)+' грн';
  if(document.getElementById('cp-gain'))document.getElementById('cp-gain').textContent='+'+fmt(fv-inv)+' грн';
}
function cPort(v) {
  const n=parseInt(v)||10000;
  document.getElementById('pt-v').textContent=fmt(n)+' грн';
  document.getElementById('pt-b').textContent=fmt(n*.3)+' грн';
  document.getElementById('pt-e').textContent=fmt(n*.4)+' грн';
  document.getElementById('pt-r').textContent=fmt(n*.15)+' грн';
  document.getElementById('pt-bb').textContent=fmt(n*.15)+' грн';
}
function cStrat() {
  const inc=parseInt(document.getElementById('st-inc')?.value)||60000;
  const sv=parseInt(document.getElementById('st-sv')?.value)||10;
  const age=parseInt(document.getElementById('st-age')?.value)||30;
  const gl=parseInt(document.getElementById('st-gl')?.value)||15;
  ['st-inc','st-sv','st-age','st-gl'].forEach(id=>{
    const el=document.getElementById(id);
    if(!el)return;
    const v=parseFloat(el.value);
    el.nextElementSibling.textContent=id==='st-sv'?v+'%':fmt(v);
  });
  const mo=inc*sv/100;
  const stocks=Math.max(20,100-age);
  const mr=.12/12,nm=gl*12;
  const cap=mo*(Math.pow(1+mr,nm)-1)/mr;
  if(document.getElementById('st-mo'))document.getElementById('st-mo').textContent=fmt(mo)+' грн';
  if(document.getElementById('st-sk'))document.getElementById('st-sk').textContent=stocks+'%';
  if(document.getElementById('st-cap'))document.getElementById('st-cap').textContent=fmt(cap)+' грн';
}

// ─────────────────────────────────────────
// RESTORE TASK STATES ON RENDER
// ─────────────────────────────────────────
function restoreTaskStates() {
  Object.keys(S.hwAnswers).forEach(key => {
    if (key.startsWith('task_')) {
      const listId = key.replace('task_', '');
      const doneIdxs = S.hwAnswers[key];
      const list = document.getElementById(listId);
      if (!list) return;
      const items = list.querySelectorAll('.task-item');
      doneIdxs.forEach(idx => {
        if (items[idx]) { items[idx].classList.add('done'); items[idx].querySelector('.task-chk').textContent='✓'; }
      });
    } else {
      const ta = document.getElementById('hw-' + key);
      if (ta && S.hwAnswers[key]) { ta.value = S.hwAnswers[key]; }
    }
  });
}

// MutationObserver to restore states after render
const observer = new MutationObserver(() => { restoreTaskStates(); });
observer.observe(document.getElementById('modules-container'), {childList:true, subtree:true});

// ─────────────────────────────────────────
// INIT
// ─────────────────────────────────────────
if (S.onboardDone) {
  document.getElementById('onboard').style.display = 'none';
  initCourse();
}
