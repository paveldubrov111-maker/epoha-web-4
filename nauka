// RENDER MODULES
// ─────────────────────────────────────────
function renderModules() {
  const c = document.getElementById('modules-container');
  c.innerHTML = '';
  MODULES.forEach((m, mi) => {
    const done = S.completedModules.includes(mi);
    const doneSet = S.completedSteps[mi] ? new Set(S.completedSteps[mi]) : new Set();
    const stDone = doneSet.size;
    const stTotal = m.steps.length;
    const pct = stTotal > 0 ? Math.round(stDone / stTotal * 100) : 0;
    const isOpen = S.activeModule === mi;
    // unlock logic based on track
    let locked = false;
    if (S.track === 'full' && mi > 0 && !S.completedModules.includes(mi-1) && stDone === 0) locked = true;
    if (S.track === 'invest' && mi < 2 && !S.completedModules.includes(mi) && stDone === 0) locked = false;
    if (S.track === 'bitbon' && mi < 4 && !S.completedModules.includes(mi) && stDone === 0) locked = false;
    if (S.track === 'invest' && mi > 2 && mi > 0 && !S.completedModules.includes(mi-1) && stDone === 0) locked = true;
    if (S.track === 'bitbon' && mi > 4 && !S.completedModules.includes(mi-1) && stDone === 0) locked = true;

    const el = document.createElement('div');
    el.className = 'mod-block' + (isOpen?' open':'') + (done?' done':'');
    el.id = 'mb-' + mi;
    el.innerHTML = `
      <div class="mod-hdr" onclick="toggleMod(${mi})">
        <div class="mod-ico" style="background:${m.color}22">${m.emoji}${done?'<span class="done-mark">✓</span>':''}</div>
        <div class="mod-info">
          <div class="mod-num">Модуль ${String(mi+1).padStart(2,'0')}</div>
          <div class="mod-name">${m.title}</div>
          <div class="mod-desc">${m.desc}</div>
        </div>
        <div class="mod-right">
          <span class="mod-xp-tag">+${m.totalXP} XP</span>
          <div class="mod-prog"><div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div><span class="prog-txt">${stDone}/${stTotal}</span></div>
        </div>
        <span class="mod-chev">▾</span>
      </div>
      <div class="lesson-body">${locked ? renderLocked() : renderLesson(m, mi, doneSet)}</div>
    `;
    c.appendChild(el);
  });
}

function renderLocked() {
  return `<div class="locked-msg"><div class="locked-ico">🔒</div><div class="locked-txt">Завершіть попередній модуль щоб розблокувати</div></div>`;
}

function renderLesson(m, mi, doneSet) {
  const cur = S.activeSteps[mi] !== undefined ? S.activeSteps[mi] : 0;
  const tabs = m.steps.map((s,si) =>
    `<button class="ltab${cur===si?' active':''}${doneSet.has(si)?' done':''}" onclick="goStep(${mi},${si})">${s.title}</button>`
  ).join('');
  const panels = m.steps.map((s, si) => `
    <div class="step-panel${cur===si?' active':''}" id="sp-${mi}-${si}">
      ${renderVideo(s)}
      <div>${s.content}</div>
      <div class="step-nav">
        <button class="btn-prev" onclick="prevStep(${mi})" ${cur===0?'disabled':''}>← Назад</button>
        <div class="step-dots">${m.steps.map((_,i)=>`<div class="s-dot${i===cur?' active':''}${doneSet.has(i)?' done':''}"></div>`).join('')}</div>
        <button class="btn-next${cur===m.steps.length-1?' fin':''}" onclick="nextStep(${mi})">
          ${cur===m.steps.length-1?'Завершити модуль ✓':'Далі →'}
        </button>
      </div>
    </div>
  `).join('');
  return `<div class="ltabs" id="lt-${mi}">${tabs}</div><div class="lesson-content" id="lc-${mi}">${panels}</div>`;
}

function renderVideo(s) {
  const hasUrl = s.videoUrl && !s.videoUrl.startsWith('YOUR_');
  const embed = url => { const m=url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/); return m?`https://www.youtube.com/embed/${m[1]}`:url; };
  return `<div class="vid-block">
    <div class="vid-lbl">${s.videoTitle}</div>
    <div class="vid-frame">
      ${hasUrl
        ? `<iframe src="${embed(s.videoUrl)}" allowfullscreen></iframe>`
        : `<div class="vid-ph"><div class="vid-ph-icon">▶</div><div class="vid-ph-txt">Відео буде додано після зйомки</div><div class="vid-ph-url">Замініть у коді: ${s.videoUrl}</div></div>`}
    </div>
    <div class="vid-dur">⏱ Тривалість: ${s.videoDuration}</div>
  </div>`;
}

// ─────────────────────────────────────────
// NAVIGATION
// ─────────────────────────────────────────
function toggleMod(mi) {
  S.activeModule = (S.activeModule === mi) ? -1 : mi;
  if (S.activeSteps[mi] === undefined) S.activeSteps[mi] = 0;
  saveState();
  renderModules();
  if (S.activeModule === mi) setTimeout(() => { document.getElementById('mb-'+mi)?.scrollIntoView({behavior:'smooth',block:'start'}); }, 80);
}

function goStep(mi, si) {
  S.activeSteps[mi] = si;
  saveState();
  renderModules();
}

function prevStep(mi) {
  const cur = S.activeSteps[mi] || 0;
  if (cur > 0) { S.activeSteps[mi] = cur-1; saveState(); renderModules(); }
}

function nextStep(mi) {
  const m = MODULES[mi];
  const cur = S.activeSteps[mi] || 0;
  if (!S.completedSteps[mi]) S.completedSteps[mi] = [];
  const doneArr = S.completedSteps[mi];
  if (!doneArr.includes(cur)) {
    doneArr.push(cur);
    addXP(m.steps[cur].xp, 'крок завершено!');
    if (cur === 0) earnBadge('first_step');
  }
  if (cur < m.steps.length - 1) {
    S.activeSteps[mi] = cur + 1;
    saveState();
    renderModules();
    setTimeout(() => { document.getElementById('mb-'+mi)?.querySelector('.lesson-body')?.scrollIntoView({behavior:'smooth',block:'start'}); }, 80);
  } else {
    if (!S.completedModules.includes(mi)) {
      S.completedModules.push(mi);
      addXP(50, `Модуль "${m.title}" завершено! 🎉`);
      earnBadge(m.badgeId);
      if (S.completedModules.length === 7) {
        earnBadge('strategist');
        setTimeout(showCompletion, 700);
      }
    }
    S.activeModule = -1;
    saveState();
    renderModules();
    updateXPUI();
  }
}

function showCompletion() {
  document.getElementById('comm-block').classList.add('show');
  document.getElementById('diploma-block').classList.add('show');
  document.getElementById('dip-name').textContent = S.userName;
  // earned badges in diploma
  const dibadges = document.getElementById('dip-badges');
  dibadges.innerHTML = S.earnedBadges.map(id => {
    const b = BADGES_DEF.find(x=>x.id===id);
    return b ? `<span class="dip-badge">${b.icon} ${b.name}</span>` : '';
  }).join('');
  document.getElementById('comm-block').scrollIntoView({behavior:'smooth'});
}

function printDiploma() {
  window.print();
}

// ─────────────────────────────────────────
// INTERACTIVE HELPERS
// ─────────────────────────────────────────
function pyr(el) {
  const o = el.classList.contains('open');
  el.closest('.pyramid').querySelectorAll('.pyr-item').forEach(i=>i.classList.remove('open'));
  if (!o) el.classList.add('open');
}

function task(el, listId, idx, xpAmt) {
  if (el.classList.contains('done')) return;
  el.classList.add('done');
  el.querySelector('.task-chk').textContent = '✓';
  // persist task state
  if (!S.hwAnswers['task_' + listId]) S.hwAnswers['task_' + listId] = [];
  if (!S.hwAnswers['task_' + listId].includes(idx)) {
    S.hwAnswers['task_' + listId].push(idx);
    addXP(xpAmt, 'завдання виконано');
    saveState();
  }
}

function quiz(btn, correct, msg) {
  const opts = btn.closest('.quiz').querySelectorAll('.q-opt');
  opts.forEach(o => o.disabled = true);
  btn.classList.add(correct ? 'correct' : 'wrong');
  const fb = btn.closest('.quiz').querySelector('.quiz-fb');
  if (fb) { fb.className = 'quiz-fb ' + (correct?'ok':'err'); fb.textContent = msg; }
  if (correct) addXP(15, 'правильна відповідь!');
}

function scen(id, btn, good, msg) {
  const wrap = document.getElementById(id);
  if (!wrap) return;
  wrap.querySelectorAll('.sc-opt').forEach(o => o.disabled = true);
  btn.classList.add(good ? 'good' : 'bad');
  const res = document.getElementById(id + '-res');
  if (res) { res.className = 'sc-res show ' + (good?'ok':'err'); res.textContent = msg; }
  if (good) addXP(20, 'вірне рішення!');
}

function saveHW(btn, key) {
  const ta = document.getElementById('hw-' + key);
  if (ta && ta.value.trim().length > 10) {
    S.hwAnswers[key] = ta.value.trim();
    saveState();
    btn.textContent = '✓ Збережено!';
    btn.disabled = true;
    btn.style.background = '#059669';
    addXP(30, 'домашнє завдання здано!');
  } else {
    btn.style.background = '#dc2626';
    btn.textContent = 'Напишіть детальніше...';
    setTimeout(() => { btn.style.background=''; btn.textContent='Зберегти ✓'; }, 2000);
  }
}

// ЗАМІНІТЬ НА ПОСИЛАННЯ ВАШОГО TELEGRAM-БОТА
