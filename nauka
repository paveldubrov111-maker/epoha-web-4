<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bitbon Academy — Фінансова стратегія на все життя</title>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0b0f;--bg2:#111318;--bg3:#181b22;
  --card:#1a1d26;--card2:#1f2330;
  --border:#2a2d3a;--border2:#363a4a;
  --text:#f0f1f5;--muted:#8b8fa8;--muted2:#5a5e72;
  --accent:#3b82f6;--accent2:#1d4ed8;
  --gold:#f59e0b;--gold2:#fbbf24;
  --green:#10b981;--green2:#059669;
  --purple:#8b5cf6;--red:#ef4444;
  --r-sm:6px;--r-md:10px;--r-lg:14px;--r-xl:20px;
}
html{scroll-behavior:smooth}
body{font-family:'Manrope',sans-serif;background:var(--bg);color:var(--text);font-size:15px;line-height:1.6;min-height:100vh}

/* ── LAYOUT ── */
.wrap{max-width:900px;margin:0 auto;padding:0 20px 100px}

/* ── ONBOARDING OVERLAY ── */
.onboard-overlay{position:fixed;inset:0;background:rgba(10,11,15,.97);z-index:1000;display:flex;align-items:center;justify-content:center;padding:20px}
.onboard-box{background:var(--card);border:1px solid var(--border2);border-radius:var(--r-xl);max-width:540px;width:100%;padding:36px 32px}
.onboard-step{display:none}.onboard-step.active{display:block}
.ob-logo{display:flex;align-items:center;gap:10px;margin-bottom:24px}
.ob-logo-icon{width:40px;height:40px;background:linear-gradient(135deg,var(--accent),var(--purple));border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;color:#fff}
.ob-logo-text{font-size:18px;font-weight:700}
.ob-logo-text span{color:var(--accent)}
.ob-title{font-family:'Playfair Display',serif;font-size:24px;margin-bottom:10px;line-height:1.3}
.ob-desc{font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:24px}
.ob-field{margin-bottom:14px}
.ob-label{font-size:12px;color:var(--muted);margin-bottom:6px;display:block}
.ob-input{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r-md);padding:11px 14px;font-size:14px;color:var(--text);font-family:'Manrope',sans-serif;transition:border-color .15s}
.ob-input:focus{outline:none;border-color:var(--accent)}
.ob-btn{width:100%;padding:13px;background:var(--accent);color:#fff;border:none;border-radius:var(--r-md);font-size:14px;font-weight:700;cursor:pointer;font-family:'Manrope',sans-serif;transition:background .15s;margin-top:6px}
.ob-btn:hover{background:var(--accent2)}
.ob-btn.purple{background:var(--purple)}.ob-btn.purple:hover{background:#7c3aed}
.ob-quiz-q{font-size:15px;font-weight:600;margin-bottom:16px;line-height:1.5}
.ob-quiz-opts{display:flex;flex-direction:column;gap:8px;margin-bottom:20px}
.ob-opt{padding:12px 16px;font-size:13px;border:1px solid var(--border2);border-radius:var(--r-md);cursor:pointer;background:transparent;text-align:left;font-family:'Manrope',sans-serif;color:var(--muted);transition:all .15s}
.ob-opt:hover{background:var(--card2);color:var(--text);border-color:var(--border2)}
.ob-opt.selected{background:rgba(59,130,246,.12);border-color:var(--accent);color:var(--text)}
.ob-progress{display:flex;gap:6px;margin-bottom:20px}
.ob-dot{flex:1;height:3px;background:var(--border);border-radius:2px;transition:background .2s}
.ob-dot.done{background:var(--accent)}
.track-cards{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.track-card{padding:14px 16px;border:1px solid var(--border2);border-radius:var(--r-md);cursor:pointer;transition:all .15s}
.track-card:hover,.track-card.selected{border-color:var(--accent);background:rgba(59,130,246,.07)}
.track-card-title{font-size:14px;font-weight:600;margin-bottom:3px}
.track-card-desc{font-size:12px;color:var(--muted)}
.skip-link{text-align:center;margin-top:14px;font-size:12px;color:var(--muted);cursor:pointer;text-decoration:underline}
.skip-link:hover{color:var(--text)}

/* ── HEADER ── */
.course-header{padding:32px 0 24px;border-bottom:1px solid var(--border);margin-bottom:28px}
.hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;flex-wrap:wrap;gap:10px}
.logo-mark{display:flex;align-items:center;gap:10px}
.logo-icon{width:34px;height:34px;background:linear-gradient(135deg,var(--accent),var(--purple));border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:800;color:#fff}
.logo-text{font-size:15px;font-weight:700}
.logo-text span{color:var(--accent)}
.hdr-pills{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.pill{background:var(--card2);border:1px solid var(--border2);border-radius:20px;padding:5px 12px;font-size:12px;font-weight:600;display:flex;align-items:center;gap:5px}
.pill.gold{color:var(--gold2)}
.pill.green{color:var(--green)}
.hdr-welcome{margin-bottom:16px}
.hdr-eyebrow{font-size:11px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.hdr-title{font-family:'Playfair Display',serif;font-size:clamp(22px,4vw,34px);line-height:1.2;margin-bottom:8px;background:linear-gradient(135deg,#fff 0%,#8b9fc8 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hdr-sub{font-size:14px;color:var(--muted);line-height:1.7}
.xp-section{background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:14px 18px}
.xp-meta{display:flex;justify-content:space-between;margin-bottom:8px}
.xp-level-name{font-size:13px;font-weight:600}
.xp-count{font-size:12px;color:var(--muted)}
.xp-track{height:7px;background:var(--bg3);border-radius:4px;overflow:hidden;margin-bottom:5px}
.xp-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--purple));transition:width .6s cubic-bezier(.4,0,.2,1)}
.xp-mile{display:flex;justify-content:space-between}
.xp-m{font-size:10px;color:var(--muted2)}

/* ── STATS ── */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:24px}
.stat{background:var(--card);border:1px solid var(--border);border-radius:var(--r-md);padding:12px 14px;text-align:center}
.stat-v{font-size:20px;font-weight:700;margin-bottom:2px}
.stat-l{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
.stat.a .stat-v{color:var(--accent)}.stat.g .stat-v{color:var(--gold2)}.stat.gr .stat-v{color:var(--green)}.stat.p .stat-v{color:var(--purple)}

/* ── BADGES ── */
.badges-row{background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px;margin-bottom:20px}
.badges-title{font-size:12px;color:var(--muted);margin-bottom:12px;text-transform:uppercase;letter-spacing:.06em}
.badges-grid{display:flex;gap:10px;flex-wrap:wrap}
.badge-item{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:default}
.badge-ico{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;border:2px solid transparent;transition:all .2s}
.badge-ico.earned{border-color:var(--gold2);background:rgba(245,158,11,.1)}
.badge-ico.locked{background:var(--bg3);filter:grayscale(1);opacity:.4}
.badge-lbl{font-size:10px;color:var(--muted);text-align:center;max-width:48px;line-height:1.3}

/* ── DAILY REVIEW ── */
.daily-block{background:linear-gradient(135deg,rgba(59,130,246,.08),rgba(139,92,246,.08));border:1px solid rgba(59,130,246,.2);border-radius:var(--r-lg);padding:18px 20px;margin-bottom:20px;display:none}
.daily-block.show{display:block}
.daily-head{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.daily-icon{width:36px;height:36px;background:rgba(59,130,246,.15);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:16px}
.daily-title{font-size:14px;font-weight:700}
.daily-sub{font-size:12px;color:var(--muted);margin-top:2px}
.daily-q{font-size:14px;font-weight:600;margin-bottom:12px;line-height:1.5}
.daily-opts{display:flex;flex-direction:column;gap:7px;margin-bottom:12px}
.d-opt{padding:10px 14px;font-size:13px;border:1px solid var(--border2);border-radius:var(--r-md);cursor:pointer;background:transparent;text-align:left;font-family:'Manrope',sans-serif;color:var(--muted);transition:all .15s}
.d-opt:hover:not(:disabled){background:var(--card2);color:var(--text)}
.d-opt.d-ok{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.4);color:var(--green)}
.d-opt.d-err{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.daily-fb{font-size:13px;padding:10px 14px;border-radius:var(--r-md);display:none;line-height:1.5}
.daily-fb.ok{background:rgba(16,185,129,.1);color:var(--green);display:block}
.daily-fb.err{background:rgba(239,68,68,.1);color:var(--red);display:block}
.daily-skip{font-size:12px;color:var(--muted2);cursor:pointer;text-decoration:underline;margin-top:8px;display:inline-block}

/* ── MODULES ── */
.sec-lbl{font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px;display:flex;align-items:center;gap:8px}
.sec-lbl::after{content:'';flex:1;height:1px;background:var(--border)}
.mod-block{background:var(--card);border:1px solid var(--border);border-radius:var(--r-xl);overflow:hidden;margin-bottom:8px;transition:border-color .2s}
.mod-block.open{border-color:var(--border2)}
.mod-block.done{border-color:rgba(16,185,129,.3)}
.mod-hdr{display:flex;align-items:center;gap:12px;padding:18px 20px;cursor:pointer;user-select:none;transition:background .15s}
.mod-hdr:hover{background:rgba(255,255,255,.02)}
.mod-ico{width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:19px;flex-shrink:0;position:relative}
.done-mark{position:absolute;bottom:-3px;right:-3px;width:15px;height:15px;background:var(--green);border-radius:50%;border:2px solid var(--card);display:flex;align-items:center;justify-content:center;font-size:8px}
.mod-info{flex:1;min-width:0}
.mod-num{font-size:10px;font-weight:600;color:var(--muted);margin-bottom:2px;text-transform:uppercase;letter-spacing:.05em}
.mod-name{font-size:14px;font-weight:700;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.mod-desc{font-size:11px;color:var(--muted)}
.mod-right{display:flex;flex-direction:column;align-items:flex-end;gap:5px;flex-shrink:0}
.mod-xp-tag{font-size:11px;font-weight:600;color:var(--gold2);background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2);padding:2px 8px;border-radius:8px}
.mod-prog{display:flex;align-items:center;gap:5px}
.prog-bar{width:56px;height:3px;background:var(--bg3);border-radius:2px;overflow:hidden}
.prog-fill{height:100%;background:var(--green);border-radius:2px;transition:width .4s}
.prog-txt{font-size:10px;color:var(--muted);min-width:26px;text-align:right}
.mod-chev{font-size:13px;color:var(--muted2);transition:transform .3s;flex-shrink:0}
.mod-block.open .mod-chev{transform:rotate(180deg)}

/* ── LESSON ── */
.lesson-body{display:none;border-top:1px solid var(--border)}
.mod-block.open .lesson-body{display:block}
.ltabs{display:flex;overflow-x:auto;scrollbar-width:none;border-bottom:1px solid var(--border);padding:0 20px;gap:2px}
.ltabs::-webkit-scrollbar{display:none}
.ltab{padding:11px 14px;font-size:12px;font-weight:600;color:var(--muted);border-bottom:2px solid transparent;cursor:pointer;white-space:nowrap;transition:all .15s;background:none;border-top:none;border-left:none;border-right:none;font-family:'Manrope',sans-serif}
.ltab:hover{color:var(--text)}
.ltab.active{color:var(--accent);border-bottom-color:var(--accent)}
.ltab.done{color:var(--green)}
.lesson-content{padding:26px 24px}
.step-panel{display:none}.step-panel.active{display:block}

/* ── VIDEO ── */
.vid-block{margin-bottom:24px}
.vid-lbl{font-size:11px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px;display:flex;align-items:center;gap:7px}
.vid-lbl::before{content:'▶';width:20px;height:20px;background:var(--accent);border-radius:5px;display:inline-flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0}
.vid-frame{position:relative;padding-bottom:56.25%;background:var(--bg3);border-radius:var(--r-lg);overflow:hidden;border:1px solid var(--border)}
.vid-frame iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none}
.vid-ph{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px}
.vid-ph-icon{width:52px;height:52px;background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.25);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px}
.vid-ph-txt{font-size:13px;color:var(--muted);text-align:center;max-width:260px;line-height:1.5}
.vid-ph-url{font-size:11px;color:var(--accent);font-family:monospace;margin-top:2px;text-align:center;word-break:break-all;max-width:320px}
.vid-dur{font-size:12px;color:var(--muted);margin-top:7px;display:flex;align-items:center;gap:4px}

/* ── THEORY ── */
.th2{font-size:17px;font-weight:700;margin-bottom:10px}
.th3{font-size:14px;font-weight:600;margin:16px 0 8px;color:var(--text)}
.tp{font-size:13px;color:var(--muted);line-height:1.8;margin-bottom:10px}
.tp strong{color:var(--text);font-weight:600}
.tp em{color:var(--gold2);font-style:normal}
.box-i{border-left:3px solid var(--accent);background:rgba(59,130,246,.06);border-radius:0 var(--r-md) var(--r-md) 0;padding:13px 15px;margin:12px 0}
.box-i .tag{font-size:10px;font-weight:700;color:var(--accent);text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px}
.box-i p,.box-w p,.box-d p{font-size:13px;color:var(--muted);line-height:1.7}
.box-i p strong,.box-w p strong,.box-d p strong{color:var(--text)}
.box-w{border-left:3px solid var(--gold);background:rgba(245,158,11,.06);border-radius:0 var(--r-md) var(--r-md) 0;padding:13px 15px;margin:12px 0}
.box-w p{color:rgba(251,191,36,.85)}
.box-d{border-left:3px solid var(--red);background:rgba(239,68,68,.06);border-radius:0 var(--r-md) var(--r-md) 0;padding:13px 15px;margin:12px 0}
.box-d p{color:rgba(239,68,68,.85)}
.formula{background:var(--bg3);border:1px solid var(--border2);border-radius:var(--r-md);padding:16px;margin:14px 0;text-align:center}
.formula-main{font-size:18px;font-weight:700;margin-bottom:5px;font-family:'Playfair Display',serif}
.formula-sub{font-size:12px;color:var(--muted)}

/* ── FLIP CARDS ── */
.flipgrid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin:14px 0}
.flipcard{perspective:800px;height:124px;cursor:pointer}
.flipcard-inner{position:relative;width:100%;height:100%;transform-style:preserve-3d;transition:transform .5s cubic-bezier(.4,0,.2,1)}
.flipcard.flipped .flipcard-inner{transform:rotateY(180deg)}
.fc-front,.fc-back{position:absolute;width:100%;height:100%;backface-visibility:hidden;border-radius:var(--r-md);padding:14px;display:flex;flex-direction:column;justify-content:center}
.fc-front{background:var(--card2);border:1px solid var(--border2)}
.fc-back{background:var(--bg3);border:1px solid var(--accent);transform:rotateY(180deg)}
.fc-icon{font-size:22px;margin-bottom:7px}
.fc-title{font-size:13px;font-weight:600;color:var(--text)}
.fc-sub{font-size:11px;color:var(--muted);margin-top:3px}
.fc-answer{font-size:12px;color:var(--muted);line-height:1.6}
.flip-hint{font-size:11px;color:var(--muted2);text-align:center;margin-bottom:7px}

/* ── SCENARIO ── */
.scenario{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px;margin:14px 0}
.sc-story{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:14px;padding:12px 14px;background:rgba(255,255,255,.03);border-radius:var(--r-md);border:1px solid var(--border)}
.sc-story strong{color:var(--text)}
.sc-q{font-size:14px;font-weight:600;margin-bottom:11px}
.sc-opts{display:flex;flex-direction:column;gap:7px}
.sc-opt{padding:11px 14px;font-size:13px;border:1px solid var(--border2);border-radius:var(--r-md);cursor:pointer;background:transparent;text-align:left;font-family:'Manrope',sans-serif;color:var(--muted);transition:all .15s;line-height:1.4}
.sc-opt:hover:not(:disabled){background:rgba(255,255,255,.04);color:var(--text)}
.sc-opt.good{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.4);color:var(--green)}
.sc-opt.bad{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.sc-res{margin-top:10px;padding:11px 14px;border-radius:var(--r-md);font-size:13px;line-height:1.6;display:none}
.sc-res.show{display:block}
.sc-res.ok{background:rgba(16,185,129,.1);color:var(--green);border:1px solid rgba(16,185,129,.2)}
.sc-res.err{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.2)}

/* ── QUIZ ── */
.quiz{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px;margin:14px 0}
.quiz-q{font-size:14px;font-weight:600;margin-bottom:12px;line-height:1.5}
.quiz-opts{display:flex;flex-direction:column;gap:7px}
.q-opt{padding:11px 14px;font-size:13px;border:1px solid var(--border2);border-radius:var(--r-md);cursor:pointer;background:transparent;text-align:left;font-family:'Manrope',sans-serif;color:var(--muted);transition:all .15s;line-height:1.4}
.q-opt:hover:not(:disabled){background:rgba(255,255,255,.04);color:var(--text)}
.q-opt.correct{background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.4);color:var(--green)}
.q-opt.wrong{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.3);color:var(--red)}
.quiz-fb{margin-top:9px;padding:11px 13px;border-radius:var(--r-md);font-size:13px;display:none;line-height:1.5}
.quiz-fb.ok{background:rgba(16,185,129,.1);color:var(--green);display:block}
.quiz-fb.err{background:rgba(239,68,68,.1);color:var(--red);display:block}

/* ── CHECKLIST ── */
.task-list{list-style:none;padding:0;margin:12px 0}
.task-item{display:flex;align-items:flex-start;gap:11px;padding:10px 0;border-bottom:1px solid var(--border);cursor:pointer;transition:opacity .15s}
.task-item:last-child{border-bottom:none}
.task-item:hover{opacity:.8}
.task-chk{width:19px;height:19px;border:1.5px solid var(--border2);border-radius:5px;flex-shrink:0;margin-top:1px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.task-item.done .task-chk{background:var(--green);border-color:var(--green);color:#fff;font-size:10px}
.task-txt{font-size:13px;color:var(--muted);line-height:1.5}
.task-item.done .task-txt{color:var(--muted2);text-decoration:line-through}

/* ── PYRAMID ── */
.pyramid{display:flex;flex-direction:column;gap:5px;margin:12px 0}
.pyr-item{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;cursor:pointer;transition:border-color .2s}
.pyr-item.open{border-color:var(--border2)}
.pyr-hd{display:flex;align-items:center;gap:9px;padding:12px 15px}
.pyr-ico{font-size:17px;flex-shrink:0}
.pyr-t{font-size:13px;font-weight:600;flex:1}
.pyr-arr{font-size:11px;color:var(--muted2);transition:transform .25s}
.pyr-item.open .pyr-arr{transform:rotate(180deg)}
.pyr-bd{display:none;padding:0 15px 13px 41px;font-size:13px;color:var(--muted);line-height:1.7}
.pyr-item.open .pyr-bd{display:block}
.pyr-bd strong{color:var(--text)}

/* ── CALC ── */
.calc{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px;margin:12px 0}
.calc-title{font-size:13px;font-weight:600;margin-bottom:14px;color:var(--text)}
.calc-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.calc-lbl{font-size:12px;color:var(--muted);min-width:170px;flex-shrink:0}
.calc-row input[type=range]{flex:1;accent-color:var(--accent)}
.calc-num{font-size:13px;font-weight:600;min-width:88px;text-align:right}
.calc-outs{display:grid;gap:7px;margin-top:12px}
.calc-outs.c2{grid-template-columns:1fr 1fr}
.calc-outs.c3{grid-template-columns:1fr 1fr 1fr}
.calc-outs.c4{grid-template-columns:1fr 1fr 1fr 1fr}
.cres{background:rgba(255,255,255,.03);border:1px solid var(--border);border-radius:var(--r-md);padding:11px;text-align:center}
.cres .cv{font-size:17px;font-weight:700;margin-bottom:2px}
.cres .cl{font-size:10px;color:var(--muted)}
.cres.a .cv{color:var(--accent)}.cres.g .cv{color:var(--gold2)}.cres.gr .cv{color:var(--green)}.cres.p .cv{color:var(--purple)}

/* ── HOMEWORK ── */
.hw{background:linear-gradient(135deg,rgba(139,92,246,.07),rgba(59,130,246,.07));border:1px solid rgba(139,92,246,.2);border-radius:var(--r-lg);padding:18px;margin:18px 0}
.hw-hd{display:flex;align-items:center;gap:9px;margin-bottom:11px}
.hw-icon{width:34px;height:34px;background:rgba(139,92,246,.15);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px}
.hw-title{font-size:14px;font-weight:700}
.hw-sub{font-size:11px;color:var(--muted);margin-top:1px}
.hw-task{font-size:13px;color:var(--muted);line-height:1.7;margin-bottom:12px}
.hw-task strong{color:var(--text)}
.hw-ta{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:var(--r-md);padding:11px 13px;font-size:13px;color:var(--text);font-family:'Manrope',sans-serif;resize:vertical;min-height:86px;line-height:1.6;transition:border-color .15s}
.hw-ta:focus{outline:none;border-color:var(--accent)}
.hw-ta::placeholder{color:var(--muted2)}
.hw-actions{display:flex;gap:8px;margin-top:9px;align-items:center;flex-wrap:wrap}
.hw-btn{padding:9px 18px;background:var(--purple);color:#fff;border:none;border-radius:var(--r-md);font-size:13px;font-weight:600;cursor:pointer;font-family:'Manrope',sans-serif;transition:opacity .15s}
.hw-btn:hover{opacity:.85}
.hw-tg{font-size:12px;color:var(--muted)}
.hw-tg a{color:var(--accent);text-decoration:none}
.hw-tg a:hover{text-decoration:underline}

/* ── STEP NAV ── */
.step-nav{display:flex;justify-content:space-between;align-items:center;margin-top:22px;padding-top:18px;border-top:1px solid var(--border)}
.btn-prev{padding:9px 16px;background:transparent;border:1px solid var(--border2);border-radius:var(--r-md);font-size:13px;font-weight:600;cursor:pointer;font-family:'Manrope',sans-serif;color:var(--muted);transition:all .15s}
.btn-prev:hover{background:var(--card2);color:var(--text)}
.btn-prev:disabled{opacity:.3;cursor:not-allowed}
.step-dots{display:flex;gap:5px;align-items:center}
.s-dot{width:7px;height:7px;border-radius:50%;background:var(--border2);transition:all .2s}
.s-dot.active{background:var(--accent);width:18px;border-radius:3px}
.s-dot.done{background:var(--green)}
.btn-next{padding:9px 20px;background:var(--accent);color:#fff;border:none;border-radius:var(--r-md);font-size:13px;font-weight:600;cursor:pointer;font-family:'Manrope',sans-serif;transition:all .15s}
.btn-next:hover{background:var(--accent2)}
.btn-next.fin{background:var(--green)}
.btn-next.fin:hover{background:var(--green2)}

/* ── LOCKED ── */
.locked-msg{padding:26px;text-align:center;color:var(--muted)}
.locked-ico{font-size:30px;margin-bottom:9px}
.locked-txt{font-size:13px;line-height:1.6}

/* ── COMMUNITY ── */
.comm-block{background:linear-gradient(135deg,var(--card2),rgba(139,92,246,.15));border:1px solid rgba(139,92,246,.3);border-radius:var(--r-xl);padding:32px 28px;margin-top:28px;text-align:center;display:none}
.comm-block.show{display:block}
.comm-ico{font-size:44px;margin-bottom:14px}
.comm-title{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;margin-bottom:9px;background:linear-gradient(135deg,#fff,var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.comm-desc{font-size:13px;color:var(--muted);max-width:440px;margin:0 auto 18px;line-height:1.8}
.comm-perks{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:22px;max-width:480px;margin-left:auto;margin-right:auto}
.comm-perk{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:var(--r-md);padding:13px 9px;font-size:11px;color:var(--muted)}
.comm-perk-i{font-size:20px;margin-bottom:5px}
.comm-btn{padding:13px 32px;background:linear-gradient(135deg,var(--purple),var(--accent));color:#fff;border:none;border-radius:var(--r-lg);font-size:14px;font-weight:700;cursor:pointer;font-family:'Manrope',sans-serif;transition:opacity .2s}
.comm-btn:hover{opacity:.88}

/* ── DIPLOMA ── */
.diploma-block{background:var(--card);border:1px solid var(--gold2);border-radius:var(--r-xl);padding:28px;margin-top:16px;text-align:center;display:none;position:relative;overflow:hidden}
.diploma-block.show{display:block}
.diploma-block::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(245,158,11,.07),transparent 60%);pointer-events:none}
.dip-ico{font-size:40px;margin-bottom:10px}
.dip-title{font-family:'Playfair Display',serif;font-size:20px;color:var(--gold2);margin-bottom:6px}
.dip-name{font-size:22px;font-weight:700;margin-bottom:4px}
.dip-sub{font-size:13px;color:var(--muted);margin-bottom:18px}
.dip-badges{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:18px}
.dip-badge{background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.3);border-radius:20px;padding:4px 12px;font-size:12px;color:var(--gold2)}
.dip-btn{padding:10px 24px;background:var(--gold);color:#000;border:none;border-radius:var(--r-md);font-size:13px;font-weight:700;cursor:pointer;font-family:'Manrope',sans-serif;transition:opacity .15s}
.dip-btn:hover{opacity:.85}

/* ── TOAST ── */
.toast{position:fixed;top:18px;right:18px;background:var(--card2);border:1px solid var(--gold);border-radius:var(--r-md);padding:11px 16px;font-size:14px;font-weight:700;color:var(--gold2);display:flex;align-items:center;gap:7px;opacity:0;transform:translateY(-8px) scale(.97);transition:all .3s;pointer-events:none;z-index:9999}
.toast.show{opacity:1;transform:none}

/* ── RESPONSIVE ── */
@media(max-width:580px){
  .stats-row{grid-template-columns:1fr 1fr}
  .flipgrid{grid-template-columns:1fr}
  .calc-lbl{min-width:120px;font-size:11px}
  .calc-outs.c3,.calc-outs.c4{grid-template-columns:1fr 1fr}
  .comm-perks{grid-template-columns:1fr 1fr}
  .onboard-box{padding:24px 20px}
}
</style>
</head>
