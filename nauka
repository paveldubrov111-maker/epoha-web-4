// ─────────────────────────────────────────
// STATE (localStorage)
// ─────────────────────────────────────────
const STORAGE_KEY = 'bitbon_academy_v3';

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (raw) return JSON.parse(raw);
  } catch(e) {}
  return {
    userName: '',
    userEmail: '',
    track: 'full',
    xp: 0,
    completedModules: [],
    completedSteps: {},
    completedTasks: 0,
    earnedBadges: [],
    activeModule: -1,
    activeSteps: {},
    hwAnswers: {},
    dailyDone: '',
    startDate: new Date().toISOString(),
    streak: 1,
    lastVisit: new Date().toDateString(),
    onboardDone: false,
  };
}

function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(S)); } catch(e) {}
}

let S = loadState();

// Update streak
const today = new Date().toDateString();
if (S.lastVisit && S.lastVisit !== today) {
  const diff = (new Date(today) - new Date(S.lastVisit)) / 86400000;
  S.streak = diff <= 1 ? (S.streak||1) + 1 : 1;
  S.lastVisit = today;
  saveState();
}

// ─────────────────────────────────────────
// ONBOARDING
// ─────────────────────────────────────────
let obAnswers = {};
let selectedTrack = 'full';

function obNext(step) {
  if (step === 2) {
    const name = document.getElementById('ob-name').value.trim();
    S.userName = name || 'Друже';
    S.userEmail = document.getElementById('ob-email').value.trim();
    saveState();
  }
  document.querySelectorAll('.onboard-step').forEach(s => s.classList.remove('active'));
  document.getElementById('ob' + step).classList.add('active');
}

function selectOb(btn, groupId, val) {
  document.querySelectorAll('#' + groupId + ' .ob-opt').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  obAnswers[groupId] = val;
}

function selectTrack(card, track) {
  document.querySelectorAll('.track-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedTrack = track;
}

function obFinish() {
  S.track = selectedTrack;
  S.onboardDone = true;
  if (!S.userName) S.userName = 'Друже';
  saveState();
  document.getElementById('onboard').style.display = 'none';
  initCourse();
}

function obSkip() {
  S.userName = 'Друже';
  S.onboardDone = true;
  S.track = 'full';
  saveState();
  document.getElementById('onboard').style.display = 'none';
  initCourse();
}

// ─────────────────────────────────────────
// INIT
// ─────────────────────────────────────────
function initCourse() {
  document.getElementById('user-name-display').textContent = S.userName;
  const trackNames = {full:'Повний курс', invest:'Трек — Інвестиції', bitbon:'Bitbon-трек'};
  document.getElementById('track-pill').textContent = trackNames[S.track] || 'Повний курс';
  document.getElementById('streak-v').textContent = S.streak;
  updateXPUI();
  renderBadges();
  renderModules();
  renderDaily();
}

if (S.onboardDone) {
  document.getElementById('onboard').style.display = 'none';
  initCourse();
}

// ─────────────────────────────────────────
// XP & LEVELS
// ─────────────────────────────────────────
function addXP(amt, label) {
  S.xp += amt;
  S.completedTasks++;
  saveState();
  updateXPUI();
  showToast(amt, label);
}

function showToast(amt, label) {
  const t = document.getElementById('toast');
  document.getElementById('toast-v').textContent = amt;
  document.getElementById('toast-l').textContent = label;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}

function updateXPUI() {
  let lvl = LEVELS[0], idx = 0;
  for (let i = 0; i < LEVELS.length; i++) { if (S.xp >= LEVELS[i].min) { lvl = LEVELS[i]; idx = i; } }
  const nxt = LEVELS[idx+1] || {min:99999};
  const pct = Math.min(100, Math.round((S.xp - lvl.min) / (nxt.min - lvl.min) * 100));
  document.getElementById('xp-fill').style.width = pct + '%';
  document.getElementById('level-name').textContent = 'Рівень ' + (idx+1) + ' — ' + lvl.name;
  document.getElementById('xp-cur').textContent = fmt(S.xp);
  document.getElementById('xp-max').textContent = fmt(nxt.min);
  document.getElementById('xp-total').textContent = fmt(S.xp);
  document.getElementById('s-xp').textContent = fmt(S.xp);
  document.getElementById('s-tasks').textContent = S.completedTasks;
  document.getElementById('s-mod').textContent = S.completedModules.length + '/7';
}

// ─────────────────────────────────────────
// BADGES
// ─────────────────────────────────────────
function earnBadge(id) {
  if (S.earnedBadges.includes(id)) return;
  S.earnedBadges.push(id);
  saveState();
  const b = BADGES_DEF.find(x => x.id === id);
  if (b) showToast(0, '🏅 Бейдж "' + b.name + '"!');
  renderBadges();
}

function renderBadges() {
  const g = document.getElementById('badges-grid');
  g.innerHTML = BADGES_DEF.map(b => `
    <div class="badge-item" title="${b.desc}">
      <div class="badge-ico ${S.earnedBadges.includes(b.id) ? 'earned' : 'locked'}">${b.icon}</div>
      <div class="badge-lbl">${b.name}</div>
    </div>
  `).join('');
}

// ─────────────────────────────────────────
// DAILY REVIEW
// ─────────────────────────────────────────
function renderDaily() {
  if (S.completedModules.length < 1) return;
  if (S.dailyDone === today) return;
  const q = DAILY_QUESTIONS[Math.floor(Math.random() * DAILY_QUESTIONS.length)];
  document.getElementById('daily-q').textContent = q.q;
  const opts = document.getElementById('daily-opts');
  opts.innerHTML = q.opts.map((o, i) =>
    `<button class="d-opt" onclick="answerDaily(this,${i===q.a},'${q.fb.replace(/'/g,"\\'")}',${q.a})">${o}</button>`
  ).join('');
  document.getElementById('daily-block').classList.add('show');
}

function answerDaily(btn, correct, fb, correctIdx) {
  const opts = btn.closest('.daily-block').querySelectorAll('.d-opt');
  opts.forEach((o,i) => { o.disabled = true; if(i===correctIdx) o.classList.add('d-ok'); });
  if (!correct) btn.classList.add('d-err');
  const fbEl = document.getElementById('daily-fb');
  fbEl.className = 'daily-fb ' + (correct?'ok':'err');
  fbEl.textContent = fb;
  if (correct) addXP(30, 'щоденне повторення!');
  S.dailyDone = today;
  saveState();
}

function skipDaily() {
  document.getElementById('daily-block').classList.remove('show');
  S.dailyDone = today;
  saveState();
}

