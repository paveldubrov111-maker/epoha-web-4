/* ── TOAST ── */
.toast{position:fixed;top:18px;right:18px;background:var(--card2);border:1px solid var(--teal);border-radius:var(--r-md);padding:11px 16px;font-size:14px;font-weight:700;color:var(--teal);display:flex;align-items:center;gap:7px;opacity:0;transform:translateY(-8px) scale(.97);transition:all .3s;pointer-events:none;z-index:9999}
