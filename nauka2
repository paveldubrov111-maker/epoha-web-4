// ─── BLOCKCHAIN DEMO ───
let bcBlocks=[{num:1,data:'Genesis Block',prev:'0000000000',hash:'a3f8d2e1b7c9'}];
const hashFn=s=>{let h=0;for(let i=0;i<s.length;i++){h=(Math.imul(31,h)+s.charCodeAt(i))|0;}return Math.abs(h).toString(16).padStart(8,'0').repeat(2).slice(0,12);}
const txs=['Аліса → Боб: 500 BTB','Боб → Марія: 200 BTB','Simcord → Contributing: 10000 BTB','Іван → Assetbox: 1000 BTB','Token Transfer: #A7F2'];
function renderChain(){
  const c=document.getElementById('bc-chain');
  c.innerHTML=bcBlocks.map((b,i)=>`
    <div class="rm-step">
      <div class="bc-block" style="border-color:${b.tampered?'var(--red)':'var(--border2)'}">
        <div class="bc-block-num">Блок #${b.num}</div>
        <div class="bc-block-hash" title="Попередній хеш">prev: ${b.prev.slice(0,8)}...</div>
        <div class="bc-block-data">${b.data}</div>
        <div class="bc-block-hash" title="Хеш цього блоку" style="color:var(--teal)">hash: ${b.hash}...</div>
      </div>
      ${i<bcBlocks.length-1?'<div class="bc-arrow">→</div>':''}
    </div>`).join('');
}
function addBlock(){
  const tx=txs[Math.floor(Math.random()*txs.length)];
  const prev=bcBlocks[bcBlocks.length-1].hash;
  const h=hashFn(tx+prev+Date.now());
  bcBlocks.push({num:bcBlocks.length+1,data:tx,prev,hash:h});
  renderChain();
  document.getElementById('bc-explain').textContent=`✅ Новий блок #${bcBlocks.length} додано. Його хеш залежить від хешу попереднього блоку — тому ланцюг неможливо підробити непомітно.`;
  addXP(5,'дослідили блокчейн');
}
function tryHack(){
  if(bcBlocks.length<3){document.getElementById('bc-explain').textContent='Спочатку додайте кілька транзакцій!';return;}
  bcBlocks[1].data='ПІДРОБЛЕНО!';bcBlocks[1].tampered=true;
  renderChain();
  document.getElementById('bc-explain').innerHTML='🚨 <strong>Спроба підробки виявлена!</strong> Хеш блоку #2 вже не відповідає тому що записано в блоці #3. В реальній мережі — всі вузли відхилять цю версію. Підробка неможлива.';
}
function resetChain(){bcBlocks=[{num:1,data:'Genesis Block',prev:'0000000000',hash:'a3f8d2e1b7c9'}];renderChain();document.getElementById('bc-explain').textContent='Ланцюг скинуто. Натисніть "Додати транзакцію" щоб почати знову.';}

