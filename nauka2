// ─── RENDER ───
function renderModules(){
  const c=document.getElementById('modules-container');c.innerHTML='';
  MODULES.forEach((m,mi)=>{
    const done=S.completedModules.includes(mi);
    const doneSet=new Set(S.completedSteps[mi]||[]);
    const stDone=doneSet.size,stTotal=m.steps.length;
    const pct=stTotal>0?Math.round(stDone/stTotal*100):0;
    const isOpen=S.activeModule===mi;
    const locked=mi>0&&!S.completedModules.includes(mi-1)&&stDone===0;
    const el=document.createElement('div');
    el.className='mod-block'+(isOpen?' open':'')+(done?' done':'');
    el.id='mb-'+mi;
    el.innerHTML=`
      <div class="mod-hdr" onclick="toggleMod(${mi})">
        <div class="mod-ico" style="background:${m.color}22">${m.emoji}${done?'<span class="done-mark">✓</span>':''}</div>
        <div class="mod-info">
          <div class="mod-num">Модуль ${String(mi+1).padStart(2,'0')}</div>
          <div class="mod-name">${m.title}</div>
          <div class="mod-desc">${m.desc}</div>
        </div>
        <div class="mod-right">
          <span class="mod-xp-tag">+${m.totalXP} XP</span>
          <div class="mod-prog"><div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div><span class="prog-txt">${stDone}/${stTotal}</span></div>
        </div>
        <span class="mod-chev">▾</span>
      </div>
      <div class="lesson-body">${locked?`<div style="padding:26px;text-align:center;color:var(--muted)"><div style="font-size:30px;margin-bottom:9px">🔒</div><div style="font-size:13px">Завершіть попередній модуль</div></div>`:renderLesson(m,mi,doneSet)}</div>`;
    c.appendChild(el);
  });
  renderRoadmap();
  restoreTasks();
}

function renderLesson(m,mi,doneSet){
  const cur=S.activeSteps[mi]!==undefined?S.activeSteps[mi]:0;
  const tabs=m.steps.map((s,si)=>`<button class="ltab${cur===si?' active':''}${doneSet.has(si)?' done':''}" onclick="goStep(${mi},${si})">${s.title}</button>`).join('');
  const panels=m.steps.map((s,si)=>`
    <div class="step-panel${cur===si?' active':''}" id="sp-${mi}-${si}">
      ${renderVid(s)}
      <div>${s.content}</div>
      <div class="step-nav">
        <button class="btn-prev" onclick="prevStep(${mi})" ${cur===0?'disabled':''}>← Назад</button>
        <div class="s-dots">${m.steps.map((_,i)=>`<div class="s-dot${i===cur?' active':''}${doneSet.has(i)?' done':''}"></div>`).join('')}</div>
        <button class="btn-next${cur===m.steps.length-1?' fin':''}" onclick="nextStep(${mi})">${cur===m.steps.length-1?'Завершити модуль ✓':'Далі →'}</button>
      </div>
    </div>`).join('');
  return `<div class="ltabs">${tabs}</div><div class="lesson-content">${panels}</div>`;
}

function renderVid(s){
  const has=s.videoUrl&&!s.videoUrl.startsWith('YOUR_');
  const emb=u=>{const m=u.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&\s]+)/);return m?`https://www.youtube.com/embed/${m[1]}`:u;};
  return `<div class="vid-block"><div class="vid-lbl">${s.videoTitle}</div><div class="vid-frame">${has?`<iframe src="${emb(s.videoUrl)}" allowfullscreen></iframe>`:`<div class="vid-ph"><div class="vid-ph-icon">▶</div><div class="vid-ph-txt">Відео буде додано після зйомки</div><div class="vid-ph-url">${s.videoUrl}</div></div>`}</div><div class="vid-dur">⏱ ${s.videoDuration}</div></div>`;
}

// ─── NAV ───
function toggleMod(mi){S.activeModule=S.activeModule===mi?-1:mi;if(S.activeSteps[mi]===undefined)S.activeSteps[mi]=0;saveState();renderModules();if(S.activeModule===mi)setTimeout(()=>document.getElementById('mb-'+mi)?.scrollIntoView({behavior:'smooth',block:'start'}),80);}
function goStep(mi,si){S.activeSteps[mi]=si;saveState();renderModules();}
function prevStep(mi){const c=S.activeSteps[mi]||0;if(c>0){S.activeSteps[mi]=c-1;saveState();renderModules();}}
function nextStep(mi){
  const m=MODULES[mi];const cur=S.activeSteps[mi]||0;
  if(!S.completedSteps[mi])S.completedSteps[mi]=[];
  if(!S.completedSteps[mi].includes(cur)){S.completedSteps[mi].push(cur);addXP(m.steps[cur].xp,'крок завершено!');}
  if(cur<m.steps.length-1){S.activeSteps[mi]=cur+1;saveState();renderModules();}
  else{
    if(!S.completedModules.includes(mi)){S.completedModules.push(mi);addXP(50,`Модуль "${m.title}" завершено! 🎉`);earnBadge(m.badgeId);}
    S.activeModule=-1;saveState();renderModules();updateXPUI();
    if(S.completedModules.length===MODULES.length)setTimeout(()=>{document.getElementById('block3-teaser').classList.add('show');document.getElementById('block3-teaser').scrollIntoView({behavior:'smooth'});},700);
  }
}

