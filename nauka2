<script>
// ─── CONSTANTS ───
const fmt = n => Math.round(n).toLocaleString('uk-UA');
const STORAGE_KEY = 'bitbon_block2_v1';

const LEVELS = [
  {min:0,   max:600,  name:"Дослідник 🔍"},
  {min:600, max:1400, name:"Аналітик 📡"},
  {min:1400,max:2800, name:"Технолог ⚙️"},
  {min:2800,max:5000, name:"Новатор 🔷"},
  {min:5000,max:99999,name:"Піонер нової економіки 🏆"}
];

const BADGES_DEF = [
  {id:'historian',  icon:'📜', name:'Історик',       desc:'Історія грошей'},
  {id:'crypter',    icon:'🔐', name:'Крипто-базис',  desc:'Як працює блокчейн'},
  {id:'tokenizer',  icon:'🪙', name:'Токенізатор',   desc:'Токенізація активів'},
  {id:'economist',  icon:'🌐', name:'Цифровий економіст',desc:'Трансформація економіки'},
  {id:'platformer', icon:'🏗️', name:'Платформер',   desc:'Платформна економіка'},
  {id:'spacer',     icon:'🚀', name:'One Space',      desc:'Модуль One Space'},
  {id:'bitboner2',  icon:'🔷', name:'Bitbon Pro',     desc:'Система Bitbon глибоко'},
  {id:'pioneer',    icon:'🏆', name:'Піонер',         desc:'Всі модулі пройдено'},
];

// ─── STATE ───
function loadState() {
  try { const r = localStorage.getItem(STORAGE_KEY); if(r) return JSON.parse(r); } catch(e){}
  return {xp:0,completedModules:[],completedSteps:{},completedTasks:0,earnedBadges:[],activeModule:-1,activeSteps:{},hwAnswers:{},streak:1,lastVisit:new Date().toDateString()};
}
function saveState(){ try{localStorage.setItem(STORAGE_KEY,JSON.stringify(S));}catch(e){} }
let S = loadState();
const today = new Date().toDateString();
if(S.lastVisit && S.lastVisit !== today){const d=(new Date(today)-new Date(S.lastVisit))/86400000;S.streak=d<=1?(S.streak||1)+1:1;S.lastVisit=today;saveState();}

// ─── XP ───
function addXP(amt, label){S.xp+=amt;S.completedTasks++;saveState();updateXPUI();showToast(amt,label);}
function showToast(amt,label){const t=document.getElementById('toast');document.getElementById('toast-v').textContent=amt;document.getElementById('toast-l').textContent=label;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2400);}
function updateXPUI(){
  let lvl=LEVELS[0],idx=0;
  for(let i=0;i<LEVELS.length;i++){if(S.xp>=LEVELS[i].min){lvl=LEVELS[i];idx=i;}}
  const nxt=LEVELS[idx+1]||{min:99999};
  const pct=Math.min(100,Math.round((S.xp-lvl.min)/(nxt.min-lvl.min)*100));
  document.getElementById('xp-fill').style.width=pct+'%';
  document.getElementById('level-name').textContent='Рівень '+(idx+1)+' — '+lvl.name;
  document.getElementById('xp-cur').textContent=fmt(S.xp);
  document.getElementById('xp-max').textContent=fmt(nxt.min);
  document.getElementById('xp-total').textContent=fmt(S.xp);
  document.getElementById('s-xp').textContent=fmt(S.xp);
  document.getElementById('s-tasks').textContent=S.completedTasks;
  document.getElementById('s-mod').textContent=S.completedModules.length+'/8';
  document.getElementById('streak-v').textContent=S.streak;
}

// ─── BADGES ───
function earnBadge(id){if(S.earnedBadges.includes(id))return;S.earnedBadges.push(id);saveState();const b=BADGES_DEF.find(x=>x.id===id);if(b)showToast(0,'🏅 Бейдж "'+b.name+'"!');renderBadges();}
function renderBadges(){const g=document.getElementById('badges-grid');g.innerHTML=BADGES_DEF.map(b=>`<div class="badge-item" title="${b.desc}"><div class="badge-ico ${S.earnedBadges.includes(b.id)?'earned':'locked'}">${b.icon}</div><div class="badge-lbl">${b.name}</div></div>`).join('');}

// ─── ROADMAP ───
function renderRoadmap(){
  const c=document.getElementById('roadmap-steps');
  c.innerHTML=MODULES.map((m,i)=>`
    <div class="rm-step">
      <div class="rm-wrap">
        <div class="rm-dot ${S.completedModules.includes(i)?'done':S.activeModule===i?'active':''}" title="${m.title}">${i+1}</div>
        <span class="rm-label">${m.emoji}</span>
      </div>
      ${i<MODULES.length-1?`<div class="rm-line ${S.completedModules.includes(i)?'done':''}"></div>`:''}
    </div>`).join('');
}

// ─── MODULE DATA ───
const MODULES = [
// ═══ MODULE 0: ІСТОРІЯ ГРОШЕЙ ═══
{
  id:0, emoji:"📜", color:"#854d0e", title:"Історія грошей",
  desc:"Від бартеру до цифрових активів · 5000 років еволюції",
  totalXP:200, badgeId:'historian',
  steps:[
    {
      title:"Від бартеру до монет", xp:65,
      videoUrl:"YOUR_YOUTUBE_URL_B2_1", videoDuration:"12–15 хв",
      videoTitle:"Урок 1: 5000 років еволюції грошей — від мушель до Bitcoin",
      content:`
        <div class="th2">Гроші — найвидатніший винахід людства</div>
        <p class="tp">До появи грошей люди обмінювались прямо — рибу на зерно, зерно на шкури. Це <strong>бартер</strong>. Проблема: щоб обмінятись, потрібно щоб обидві сторони мали саме те що треба одна одній. Математично — майже неможливо.</p>
        <div class="box-i"><div class="tag">Проблема подвійного збігу потреб</div><p>Якщо я маю рибу і хочу зерно — мені потрібен рибалка якому потрібна саме моя риба. В місті з 1000 людей — шанс знайти такого збіг близький до нуля.</p></div>
        <div class="timeline" id="tl-history">
          <div class="tl-item" onclick="expandTL(this)">
